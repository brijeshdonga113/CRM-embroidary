rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Per-user workspace: each signed-in user owns a `users/{uid}` document
    // (general business info) plus subcollections for their own data.
    // No cross-user access — uid in the path must match the caller's uid.
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      match /clients/{clientId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
      match /inventoryItems/{itemId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
      match /billings/{billingId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
      match /stockMovements/{movementId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
      match /orders/{orderId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
      match /purchaseOrders/{purchaseOrderId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
